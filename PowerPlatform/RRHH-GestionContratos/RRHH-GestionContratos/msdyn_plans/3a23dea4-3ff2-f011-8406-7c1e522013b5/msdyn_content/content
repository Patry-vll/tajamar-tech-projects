  "personasAndUserStories": [
    {
      "user": {
        "id": "Empleado",
        "name": "Empleado",
        "description": "Usuario que registra gastos y adjunta justificantes para material de laboratorio.",
        "image": "https://content.powerapps.com/resource/makerx/static/media/PersonStar.d9309781.svg"
      },
      "userStories": [
        {
          "id": "us01",
          "description": "Registrar un gasto de laboratorio para que pueda gestionar mis compras y su posterior validación.",
          "userType": "Empleado"
        },
        {
          "id": "us02",
          "description": "Adjuntar justificante de gasto para que el gasto tenga soporte documental válido.",
          "userType": "Empleado"
        },
        {
          "id": "us03",
          "description": "Clasificar el gasto manualmente para asegurar una correcta imputación contable o de proyecto.",
          "userType": "Empleado"
        },
        {
          "id": "us04",
          "description": "Revisar el estado de mis gastos presentados para conocer si han sido aprobados o rechazados.",
          "userType": "Empleado"
        },
        {
          "id": "us05",
          "description": "Añadir detalle y líneas de conceptos al gasto para reflejar con precisión todos los importes y productos.",
          "userType": "Empleado"
        },
        {
          "id": "us06",
          "description": "Editar o corregir mis gastos en estado borrador para subsanar errores antes de enviarlos a aprobación.",
          "userType": "Empleado"
        },
        {
          "id": "us07",
          "description": "Recibir notificación cuando el gasto sea aprobado o rechazado para conocer su resolución.",
          "userType": "Empleado"
        }
      ]
    },
    {
      "user": {
        "id": "Aprobador de gastos",
        "name": "Aprobador de gastos",
        "description": "Persona responsable de revisar, aprobar o rechazar los gastos registrados por los empleados.",
        "image": "https://content.powerapps.com/resource/makerx/static/media/PersonNote.bac78e19.svg"
      },
      "userStories": [
        {
          "id": "us08",
          "description": "Visualizar los gastos pendientes de mi aprobación para facilitar la validación financiera.",
          "userType": "Aprobador de gastos"
        },
        {
          "id": "us09",
          "description": "Revisar justificantes de gasto para comprobar su validez antes de aprobar o rechazar.",
          "userType": "Aprobador de gastos"
        },
        {
          "id": "us10",
          "description": "Aprobar o rechazar gastos registrados para asegurar el control y la transparencia de la empresa.",
          "userType": "Aprobador de gastos"
        },
        {
          "id": "us11",
          "description": "Dejar comentarios de rechazo para que el empleado conozca el motivo y pueda corregir el gasto.",
          "userType": "Aprobador de gastos"
        },
        {
          "id": "us12",
          "description": "Filtrar y visualizar gastos por centro de coste, proyecto o usuario para agilizar la revisión.",
          "userType": "Aprobador de gastos"
        }
      ]
    },
    {
      "user": {
        "id": "Administrador de sistema",
        "name": "Administrador de sistema",
        "description": "Usuario encargado de la configuración, mantenimiento y administración de reglas y catálogos.",
        "image": "https://content.powerapps.com/resource/makerx/static/media/PersonAccounts.bd1e9daf.svg"
      },
      "userStories": [
        {
          "id": "us13",
          "description": "Configurar categorías y subcategorías de gasto para garantizar una correcta clasificación de los gastos.",
          "userType": "Administrador de sistema"
        },
        {
          "id": "us14",
          "description": "Definir reglas de clasificación automática para simplificar el registro y evitar errores manuales.",
          "userType": "Administrador de sistema"
        },
        {
          "id": "us15",
          "description": "Gestionar los catálogos de productos y proveedores para mantener la información actualizada.",
          "userType": "Administrador de sistema"
        },
        {
          "id": "us16",
          "description": "Asignar roles y permisos de usuario para definir quién puede aprobar y visualizar gastos globales.",
          "userType": "Administrador de sistema"
        }
      ]
    }
